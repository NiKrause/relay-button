{
	"name": "@le-space/playwright",
	"version": "0.6.34",
	"description": "Reusable Playwright fixtures and Relay Button lifecycle helpers.",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"dependencies": {
		"@le-space/aleph-bootstrap": "workspace:*",
		"@le-space/core": "workspace:*"
	},
	"bin": {
		"playwright-runner-cleanup": "./dist/cleanup-cli.js"
	},
	"peerDependencies": {
		"@playwright/test": ">=1.61.1 <1.62.0"
	},
	"devDependencies": {
		"@playwright/test": "1.61.1"
	},
	"scripts": {
		"build": "node --check ./src/index.ts && node --check ./src/cleanup-cli.ts",
		"build:publish": "tsup src/index.ts src/cleanup-cli.ts --format esm --dts --clean --tsconfig tsconfig.publish.json --external @playwright/test",
		"test": "node --test ./test/**/*.test.ts",
		"lint": "echo \"playwright lint placeholder\""
	}
}
